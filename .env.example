# Copy this file to .env and fill in your real values.
# NEVER share your .env file or commit it to git — it contains secrets.

# ── Dashboard authentication ──────────────────────────────────────────────────
# Set a strong random string here. Required to access any dashboard endpoint.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_KEY=your_dashboard_api_key_here

# ── Telegram (for notifications) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── GoPlus Security (contract safety checks) ──────────────────────────────────
# Free tier at: https://docs.gopluslabs.io
# Works without a key but rate-limited — get a free key to increase limits.
GOPLUS_API_KEY=

# ── Helius (Solana on-chain data) ─────────────────────────────────────────────
# Free tier at: https://www.helius.dev — 100k credits/month, no credit card needed.
HELIUS_API_KEY=your_helius_api_key_here

# ── BSCScan (BNB Chain on-chain data) ─────────────────────────────────────────
# Free at: https://bscscan.com/apis — sign up and generate a free API key.
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ── Birdeye (Solana token analytics — optional, Phase 3) ─────────────────────
BIRDEYE_API_KEY=

# ── Arkham Intelligence (wallet entity labeling — optional) ───────────────────
# Enriches wallet labels: "smart_degen" → "Jump Trading" / "Wintermute" etc.
# Get a key at: https://intel.arkm.com/api
ARKHAM_API_KEY=

# ── AI (for research and decision reasoning — Phase 3) ───────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Phase 7: Live execution keys (leave blank for paper trading) ─────────────
# Solana — Base58 encoded 64-byte keypair from your Solana wallet
# Get it from Phantom: Settings → Export Private Key
SOLANA_PRIVATE_KEY=

# BNB Chain — hex private key (0x...) from MetaMask or similar
# MetaMask: Account Details → Export Private Key
BNB_PRIVATE_KEY=
BNB_WALLET_ADDRESS=

# BNB RPC URL — defaults to public BSC node if blank
# For better reliability use a dedicated provider (e.g. Ankr, QuickNode)
BNB_RPC_URL=
